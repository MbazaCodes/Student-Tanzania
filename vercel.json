{
  "buildCommand": "bun run build",
  "outputDirectory": ".output/public",
  "installCommand": "bun install",
  "framework": null,
  "functions": {
    "api/server.js": {
      "runtime": "nodejs20.x",
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/((?!_nitro|assets|favicon).*)",
      "destination": "/api/server"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
